{
  "name": "livepair",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter !livepair dev",
    "build": "pnpm -r --filter !livepair build",
    "lint": "pnpm -r --filter !livepair lint",
    "typecheck": "pnpm -r --filter !livepair typecheck",
    "test": "pnpm -r --filter !livepair test",
    "test:coverage": "pnpm --filter @livepair/shared-types test && pnpm --filter @livepair/api test:coverage && pnpm --filter @livepair/desktop test:coverage",
    "lint:api": "pnpm --filter @livepair/api lint",
    "lint:desktop": "pnpm --filter @livepair/desktop lint",
    "lint:shared-types": "pnpm --filter @livepair/shared-types lint",
    "typecheck:api": "pnpm --filter @livepair/api typecheck",
    "typecheck:desktop": "pnpm --filter @livepair/desktop typecheck",
    "typecheck:shared-types": "pnpm --filter @livepair/shared-types typecheck",
    "test:api": "pnpm --filter @livepair/api test",
    "test:desktop": "pnpm --filter @livepair/desktop test",
    "test:shared-types": "pnpm --filter @livepair/shared-types test",
    "verify:api": "pnpm lint:api && pnpm typecheck:api && pnpm test:api",
    "verify:desktop": "pnpm lint:desktop && pnpm typecheck:desktop && pnpm test:desktop",
    "verify:shared-types": "pnpm lint:shared-types && pnpm typecheck:shared-types && pnpm test:shared-types"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@9.0.0"
}
