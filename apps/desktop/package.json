{
  "name": "@livepair/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@livepair/shared-types": "workspace:*",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
