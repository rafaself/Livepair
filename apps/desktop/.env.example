# Reference only: the normal local flow reads these values from `../../.env`.
# Keep this file aligned with the root `.env.example`.

# These values document the desktop-side local defaults.
# They only need to appear in the root `.env` when you want to override them.

# Opens Electron devtools automatically in desktop development mode when set to true.
# This is a developer convenience flag only; it is not required for normal app execution.
OPEN_DEVTOOLS=false

# Shared secret sent by the desktop main process when calling POST /session/token.
# Must match the API app's SESSION_TOKEN_AUTH_SECRET value. This stays in main-process env only.
SESSION_TOKEN_AUTH_SECRET=livepair-local-session-token-secret

# Desktop main-process base URL used for health, token, and chat-memory calls.
# This replaces the in-app backend URL setting. Keep it in the root `.env` for local overrides.
BACKEND_URL=http://localhost:3000

# Overrides the Gemini Live model resource used by the desktop renderer.
# Required for speech mode and must use the `models/...` resource format.
VITE_LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025

# Selects the Gemini Live API version used to derive the websocket endpoint.
# Required for speech mode. Current ephemeral-token speech sessions require: v1alpha
VITE_LIVE_API_VERSION=v1alpha

# Voice response modality plus transcript capabilities are fixed by the shared
# constrained-session contract used by both the backend token issuer and the
# renderer. They are no longer overridden from desktop env.

# Sets the Gemini media resolution enum used for speech-mode screen sharing.
# Defaults to MEDIA_RESOLUTION_LOW when unset so screen context stays conservative on latency/cost.
# Supported values: MEDIA_RESOLUTION_LOW, MEDIA_RESOLUTION_MEDIUM, MEDIA_RESOLUTION_HIGH
VITE_LIVE_MEDIA_RESOLUTION=MEDIA_RESOLUTION_LOW

# Enables Gemini Live context window compression setup for voice sessions.
# Default behavior when unset: enabled for voice sessions, disabled for text sessions.
# Supported values: true, false
VITE_LIVE_CONTEXT_COMPRESSION=true
