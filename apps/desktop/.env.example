# Opens Electron devtools automatically in desktop development mode when set to true.
# This is a developer convenience flag only; it is not required for normal app execution.
OPEN_DEVTOOLS=

# Overrides the Gemini Live model resource used by the desktop renderer.
# Required for speech mode and must use the `models/...` resource format.
VITE_LIVE_MODEL=

# Selects the Gemini Live API version used to derive the websocket endpoint.
# Required for speech mode. Current ephemeral-token speech sessions require: v1alpha
VITE_LIVE_API_VERSION=

# Controls the response modality for voice sessions.
# Required for speech mode.
# Supported values: AUDIO
VITE_LIVE_VOICE_RESPONSE_MODALITY=

# Enables Gemini input audio transcription for voice sessions.
# Defaults to false when unset.
# Supported values: true, false
VITE_LIVE_INPUT_AUDIO_TRANSCRIPTION=

# Enables Gemini output audio transcription for voice sessions.
# Defaults to false when unset.
# Supported values: true, false
VITE_LIVE_OUTPUT_AUDIO_TRANSCRIPTION=

# Sets the Gemini media resolution enum for future media-capable sessions.
# Defaults to MEDIA_RESOLUTION_LOW when unset.
# Supported values: MEDIA_RESOLUTION_LOW, MEDIA_RESOLUTION_MEDIUM, MEDIA_RESOLUTION_HIGH
VITE_LIVE_MEDIA_RESOLUTION=

# Enables Gemini Live session resumption for voice sessions.
# Defaults to true when unset. Set to false to opt out.
# Supported values: true, false
VITE_LIVE_SESSION_RESUMPTION=

# Enables Gemini Live context window compression setup for voice sessions.
# Default behavior when unset: enabled for voice sessions, disabled for text sessions.
# Supported values: true, false
VITE_LIVE_CONTEXT_COMPRESSION=
