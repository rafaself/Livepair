# Backend HTTP listen port.
# Local default is 3000 when unset.
PORT=

# Backend bind host.
# Local default is 127.0.0.1 when unset.
# Set to 0.0.0.0 when running the local observability Docker stack so Prometheus can scrape /metrics.
HOST=

# Server-side Gemini credential used to mint short-lived session tokens.
# Must never be exposed to the desktop client.
GEMINI_API_KEY=

# PostgreSQL connection string used by backend migrations and the Postgres persistence foundation.
# Local Docker default: postgres://livepair:livepair@127.0.0.1:5432/livepair
DATABASE_URL=

# Lifetime in seconds for the ephemeral token returned by /session/token.
# Local default is 60 when unset.
EPHEMERAL_TOKEN_TTL_SECONDS=

# Planned session/checkpoint store connection string.
# Present now so backend configuration stays explicit as the roadmap expands.
REDIS_URL=

# Set to true to start the Nest app without binding the HTTP server.
# Useful for tests or environments where process startup is needed without opening a port.
DISABLE_HTTP_LISTEN=
