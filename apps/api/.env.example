# Reference only: the normal local flow reads these values from `../../.env`.
# Keep this file aligned with the root `.env.example`.

# This file documents API-only values plus the shared secret that must match
# the desktop main process. Desktop-only values belong in `apps/desktop/.env.example`.
#
# Only `GEMINI_API_KEY` needs a real value for the normal local flow.
# The remaining entries document the local defaults and can be overridden from the root `.env`.

# Backend HTTP listen port.
# Root local default: 3000. Cloud Run injects this automatically.
PORT=3000

# Backend bind host.
# Root local default: 0.0.0.0.
# Cloud Run services must listen on 0.0.0.0.
HOST=0.0.0.0

# Explicit comma-separated browser origins allowed by API CORS.
# Leave empty to deny browser cross-origin requests by default while still allowing
# non-browser callers without an Origin header.
CORS_ALLOWED_ORIGINS=

# Server-side Gemini credential used to mint short-lived session tokens.
# Must never be exposed to the desktop client.
# Production should later source this from Secret Manager.
GEMINI_API_KEY=

# Shared secret required by POST /session/token and /chat-memory/*.
# Must match the desktop app's SESSION_TOKEN_AUTH_SECRET value.
# Local development may keep this sample value, but production must replace it and
# later source it from Secret Manager.
SESSION_TOKEN_AUTH_SECRET=livepair-local-session-token-secret

# Gemini Live model resource that the backend locks ephemeral tokens to.
# Must match the desktop app's VITE_LIVE_MODEL value and use the `models/...` format.
SESSION_TOKEN_LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025

# Maximum authenticated token requests allowed per client IP within the rate-limit window.
# Root local default: 5.
SESSION_TOKEN_RATE_LIMIT_MAX_REQUESTS=5

# Fixed-window rate-limit duration for POST /session/token, in milliseconds.
# Root local default: 60000.
SESSION_TOKEN_RATE_LIMIT_WINDOW_MS=60000

# PostgreSQL connection string used by backend migrations and the Postgres persistence foundation.
# Treat this as a secret when it contains deploy credentials.
# Local Docker default: postgres://livepair:livepair@127.0.0.1:5432/livepair
DATABASE_URL=postgres://livepair:livepair@127.0.0.1:5432/livepair

# Lifetime in seconds for the ephemeral token returned by /session/token.
# Root local default: 60.
EPHEMERAL_TOKEN_TTL_SECONDS=60

# Gemini model used for backend-managed project knowledge retrieval.
# This powers the File Search query step and is independent of the Live speech model.
PROJECT_KNOWLEDGE_SEARCH_MODEL=models/gemini-2.5-flash

# Optional explicit File Search store resource name (for example fileSearchStores/...).
# Leave empty to let the backend find or create the store by display name.
PROJECT_KNOWLEDGE_FILE_SEARCH_STORE=

# Display name used when the backend auto-creates or auto-discovers the curated project-knowledge store.
PROJECT_KNOWLEDGE_FILE_SEARCH_STORE_DISPLAY_NAME=livepair-project-knowledge

# Set to true to start the Nest app without binding the HTTP server.
# Useful for tests or environments where process startup is needed without opening a port.
DISABLE_HTTP_LISTEN=false
