{
  "name": "@livepair/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc",
    "db:check": "ts-node -r tsconfig-paths/register src/database/scripts/checkConnection.ts",
    "db:migrate": "DATABASE_URL=\"${DATABASE_URL:-postgres://livepair:livepair@127.0.0.1:5432/livepair}\" node-pg-migrate up -m src/database/migrations -t schema_migrations --envPath ../../.env",
    "db:migrate:down:all": "DATABASE_URL=\"${DATABASE_URL:-postgres://livepair:livepair@127.0.0.1:5432/livepair}\" node-pg-migrate down --all -m src/database/migrations -t schema_migrations --envPath ../../.env",
    "db:migration:create": "node-pg-migrate create -m src/database/migrations -j sql",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:chat-memory": "jest --runInBand src/chat-memory/chat-summary.spec.ts src/chat-memory/chat-memory.service.spec.ts src/chat-memory/chat-memory.repository.db.spec.ts src/chat-memory/chat-memory.http.db.spec.ts",
    "test:coverage": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@livepair/shared-types": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.18.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.spec.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  }
}
