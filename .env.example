# Main local config for normal evaluation from the repository root.
# Copy this file to `.env`, then point the app-local dotenv files at it:
#   ln -sf ../../.env apps/api/.env
#   ln -sf ../../.env apps/desktop/.env
#
# The per-app `.env.example` files remain the detailed reference if you need
# deeper tuning, but the root `.env` is the primary quick-start setup file.

# REQUIRED: server-side Gemini credential used by POST /session/token.
# Never expose this in the desktop client.
GEMINI_API_KEY=

# Shared secret used by the desktop main process when requesting session tokens.
# Keep this value the same for the API and desktop.
SESSION_TOKEN_AUTH_SECRET=livepair-local-dev-secret

# Keep the backend token model and desktop Live model aligned.
SESSION_TOKEN_LIVE_MODEL=models/gemini-2.0-flash-exp
VITE_LIVE_MODEL=models/gemini-2.0-flash-exp

# Required speech-mode settings for the current local flow.
VITE_LIVE_API_VERSION=v1alpha
VITE_LIVE_VOICE_RESPONSE_MODALITY=AUDIO

# Local Docker Postgres default used by the API and migrations.
DATABASE_URL=postgres://livepair:livepair@127.0.0.1:5432/livepair

# Optional local overrides and quality-of-life flags.
PORT=3000
HOST=127.0.0.1
OPEN_DEVTOOLS=false
VITE_LIVE_INPUT_AUDIO_TRANSCRIPTION=false
VITE_LIVE_OUTPUT_AUDIO_TRANSCRIPTION=false
VITE_LIVE_MEDIA_RESOLUTION=MEDIA_RESOLUTION_LOW
VITE_LIVE_SESSION_RESUMPTION=true
VITE_LIVE_CONTEXT_COMPRESSION=true
EPHEMERAL_TOKEN_TTL_SECONDS=60
SESSION_TOKEN_RATE_LIMIT_MAX_REQUESTS=5
SESSION_TOKEN_RATE_LIMIT_WINDOW_MS=60000

# Docker Compose defaults from the repository root.
POSTGRES_DB=livepair
POSTGRES_USER=livepair
POSTGRES_PASSWORD=livepair
POSTGRES_PORT=5432

# Optional or planned values that are not required for the normal quick start.
REDIS_URL=
DISABLE_HTTP_LISTEN=
