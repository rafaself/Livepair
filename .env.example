# Copy this file to `.env` in the repository root for local development.
# The normal local flow reads runtime config from this root file.
#
# The app-local `.env.example` files are reference-oriented and should stay
# aligned with this file, but they are not required for the normal quick start.
#
# To avoid confusion, the sections below are grouped by who reads each value:
# - local infrastructure only (`docker compose` / local Postgres)
# - API service only (`apps/api`)
# - desktop only (`apps/desktop`)
# - shared between desktop and API (must match on both sides)

# *-*-*-*-*-*-*-*-*-* IMPORTANT *-*-*-*-*-*-*-*-*-*
# REQUIRED FOR THE API SERVICE: set this value for the normal local flow.
# The backend fails fast at startup when it is missing.
GEMINI_API_KEY=

# Everything below has a sensible local default.
# Keep an entry only when you want to override that default from the root `.env`.

# ============================================================================
# Local infrastructure only (`docker compose` / local Postgres)
# ============================================================================

# Local Docker Postgres defaults used only by `docker compose`.
POSTGRES_DB=livepair
POSTGRES_USER=livepair
POSTGRES_PASSWORD=livepair
POSTGRES_PORT=5432

# ============================================================================
# API service only (`apps/api`)
# ============================================================================

# Backend HTTP listen port used only by `apps/api`.
# Cloud Run injects this automatically.
PORT=3000

# Backend bind host used only by `apps/api`.
# This is the local bind address for `app.listen(...)`, not the public API URL.
# Cloud Run services must listen on 0.0.0.0.
HOST=0.0.0.0

# Explicit comma-separated browser origins allowed only by `apps/api` CORS.
# Leave empty to block browser cross-origin requests by default; non-browser requests
# without an Origin header still work (desktop main-process, curl, uptime probes).
CORS_ALLOWED_ORIGINS=

# Gemini Live model resource that the backend locks ephemeral tokens to.
# Read only by `apps/api`.
# Must match the desktop app's `VITE_LIVE_MODEL` value and use the `models/...` format.
SESSION_TOKEN_LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025

# Maximum authenticated token requests allowed per client IP within the rate-limit window.
# Read only by `apps/api`.
SESSION_TOKEN_RATE_LIMIT_MAX_REQUESTS=5

# Fixed-window rate-limit duration for `POST /session/token`, in milliseconds.
# Read only by `apps/api`.
SESSION_TOKEN_RATE_LIMIT_WINDOW_MS=60000

# PostgreSQL connection string used by `apps/api` migrations and persistence.
# Treat as a secret when it contains deploy credentials.
DATABASE_URL=postgres://livepair:livepair@127.0.0.1:5432/livepair

# Lifetime in seconds for the ephemeral token returned by `/session/token`.
# Read only by `apps/api`.
EPHEMERAL_TOKEN_TTL_SECONDS=60

# Gemini model used for backend-managed project knowledge retrieval.
# Read only by `apps/api`.
# This is separate from the Live speech model and powers the File Search query step.
PROJECT_KNOWLEDGE_SEARCH_MODEL=models/gemini-2.5-flash

# Optional explicit File Search store resource name (for example `fileSearchStores/...`).
# Read only by `apps/api`.
# Leave empty to let the backend find or create the store by display name.
PROJECT_KNOWLEDGE_FILE_SEARCH_STORE=

# Display name used when the backend auto-creates or auto-discovers the curated project-knowledge store.
# Read only by `apps/api`.
PROJECT_KNOWLEDGE_FILE_SEARCH_STORE_DISPLAY_NAME=livepair-project-knowledge

# Set to `true` to start `apps/api` without binding the HTTP server.
DISABLE_HTTP_LISTEN=false

# ============================================================================
# Shared between desktop and API
# ============================================================================

# Shared secret sent by the desktop main process and validated by `apps/api`.
# Must match on both sides for `POST /session/token` and `/chat-memory/*`.
# Local development may keep this sample value, but production must replace it and
# later store it in Secret Manager.
SESSION_TOKEN_AUTH_SECRET=0575c801d1ab3201c161a14f46129e1c093d4ba89c70961207bd169305bc08d8

# ============================================================================
# Desktop only (`apps/desktop`)
# ============================================================================

# Opens Electron devtools automatically in desktop development mode when set to `true`.
OPEN_DEVTOOLS=false

# Desktop main-process base URL used for health, token, and chat-memory calls.
# Use this to point the desktop app at a remote API. Do not put that URL in `HOST`.
BACKEND_URL=http://localhost:3000

# Desktop renderer Gemini Live speech-mode config.
VITE_LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
VITE_LIVE_API_VERSION=v1alpha

# Voice modality, transcript support, and session resumption are fixed by the
# shared constrained-session contract; they are no longer overridden from env.
VITE_LIVE_MEDIA_RESOLUTION=MEDIA_RESOLUTION_LOW
VITE_LIVE_CONTEXT_COMPRESSION=true
