# Copy this file to terraform.tfvars and replace the example values before apply.
# The placeholder password keeps the example reviewable, but a real environment
# must supply a unique secret value from outside version control.

project_id       = "your-gcp-project-id"
region           = "us-central1"
environment_name = "dev"
naming_prefix    = "livepair"

database = {
  version             = "POSTGRES_16"
  tier                = "db-custom-1-3840"
  availability_type   = "ZONAL"
  disk_size_gb        = 10
  disk_type           = "PD_SSD"
  backup_enabled      = false
  ipv4_enabled        = true
  deletion_protection = false
  database_name       = "livepair"
  app_user_name       = "livepair"
  app_user_password   = "replace-me-before-apply"
}

api_service = {
  # Keep this on a valid bootstrap image in Artifact Registry for first create/recreate.
  # Later image rollouts come from cloudbuild.yaml rather than Terraform.
  image                 = "us-central1-docker.pkg.dev/your-gcp-project-id/livepair-dev-containers/api:bootstrap"
  allow_unauthenticated = true
  ingress               = "INGRESS_TRAFFIC_ALL"
  deletion_protection   = false
  min_instance_count    = 0
  max_instance_count    = 2
  timeout               = "300s"
  container_port        = 8080
  cpu                   = "1"
  memory                = "512Mi"
  cpu_idle              = true
  startup_cpu_boost     = true
}

api_runtime = {
  node_env                              = "production"
  cors_allowed_origins                  = []
  session_token_live_model              = "models/gemini-2.5-flash-native-audio-preview-12-2025"
  session_token_rate_limit_max_requests = 5
  session_token_rate_limit_window_ms    = 60000
  ephemeral_token_ttl_seconds           = 60
  project_knowledge_search_model        = "models/gemini-2.5-flash"
  project_knowledge_file_search_store   = ""
  project_knowledge_file_search_store_display_name = "livepair-project-knowledge"
}

api_secret_versions = {
  gemini_api_key            = "latest"
  session_token_auth_secret = "latest"
  database_url              = "latest"
}

monitoring = {
  health_check_path      = "/health"
  uptime_check_period    = "60s"
  timeout                = "10s"
  alert_failure_duration = "120s"
  telemetry_error_spike_alignment_period  = "300s"
  telemetry_error_spike_threshold         = 3
  telemetry_started_absence_duration      = "900s"
  telemetry_connect_latency_alignment_period = "300s"
  telemetry_connect_latency_threshold_ms     = 2500

  # Create notification channels outside this repo, then attach their full
  # resource names here to keep the alert policy wiring in Terraform.
  # Example:
  # notification_channel_names = [
  #   "projects/your-gcp-project-id/notificationChannels/1234567890123456789",
  # ]
  notification_channel_names = []
}
